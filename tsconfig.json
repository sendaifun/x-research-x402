{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ]
}
